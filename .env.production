# TraceVault Frontend — Production Environment
# Set VITE_API_URL to your Render backend URL.
#
# Example: If your backend is deployed at https://tracevault-api.onrender.com
# Then set: VITE_API_URL=https://tracevault-api.onrender.com
#
# This is REQUIRED for production builds. Without it, the frontend
# will try to use '/api' which needs a proxy (only available in dev).

VITE_API_URL=https://tracevault-api.onrender.com
