# ForensiChain Backend Configuration

# ═══════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# ═══════════════════════════════════════════════════════════════
# MONGODB
# ═══════════════════════════════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017/forensichain
MONGODB_DB_NAME=forensichain

# ═══════════════════════════════════════════════════════════════
# REDIS (Upstash – REST based)
# ═══════════════════════════════════════════════════════════════
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ═══════════════════════════════════════════════════════════════
# JWT
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=change-this-to-a-256-bit-secret-key-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-this-to-another-256-bit-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════════
# FILE STORAGE
# ═══════════════════════════════════════════════════════════════
# Options: "local" or "s3"
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/evidence
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_ENDPOINT=
FILE_HASH_ALGORITHM=sha256
FILE_MAX_SIZE_MB=500
S3_MULTIPART_UPLOAD=true
S3_MULTIPART_THRESHOLD_MB=50
S3_PART_SIZE_MB=10

# ═══════════════════════════════════════════════════════════════
# ENCRYPTION
# ═══════════════════════════════════════════════════════════════
ENCRYPTION_KEY=change-this-to-a-64-char-hex-key-in-production
ENCRYPTION_ALGORITHM=aes-256-gcm

# ═══════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ═══════════════════════════════════════════════════════════════
# CRON SCHEDULES
# ═══════════════════════════════════════════════════════════════
LEDGER_ANCHOR_CRON=0 0 * * *
INTEGRITY_SCAN_CRON=0 2 * * *
AUDIT_ARCHIVE_CRON=0 3 * * 0

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=debug
